{
  "name": "photon-grid",
  "private": true,
  "version": "1.0.0",
  "description": "Photon Grid monorepo",
  "license": "MIT",

  "packageManager": "pnpm@10.13.1",

 "scripts": {
    "build": "pnpm -r build",
    "build:watch": "pnpm -r build:watch",
    "dev": "pnpm -r --parallel dev",
