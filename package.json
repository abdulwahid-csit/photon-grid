{
  "name": "photon-grid",
  "version": "1.0.0",
  "description": "Professional zero-dependency data grid core engine",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "build:watch": "tsc --project tsconfig.json --watch",
    "typecheck": "tsc --noEmit",
    "demo": "npx esbuild demo/demo.ts --bundle --outfile=demo/demo.bundle.js --format=iife --global-name=PhotonGridDemo --sourcemap --target=es2020 --platform=browser",
    "demo:inventory": "npx esbuild demo/inventory-demo.ts --bundle --outfile=demo/inventory-demo.bundle.js --format=iife --global-name=PhotonGridInventoryDemo --sourcemap --target=es2020 --platform=browser",
    "demo:tree": "npx esbuild demo/tree-data-demo.ts --bundle --outfile=demo/tree-data-demo.bundle.js --format=iife --global-name=PhotonGridTreeDemo --sourcemap --target=es2020 --platform=browser"
  },
  "keywords": [
    "data-grid",
    "table",
    "zero-dependency",
    "typescript"
  ],
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.28.1",
    "typescript": "^5.9.3"
  }
}
