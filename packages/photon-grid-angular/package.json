{
  "name": "photon-grid-angular",
  "version": "1.0.2",
  "description": "Angular wrapper for Photon Grid — an enterprise-grade, framework-agnostic TypeScript data grid.",
  "author": "Abdul Wahid",
  "license": "MIT",
  "scripts": {
    "clean": "npx rimraf dist",
    "build": "ng-packagr -p ng-package.json -c tsconfig.lib.json",
    "build:watch": "ng-packagr -p ng-package.json -c tsconfig.lib.json --watch",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@angular/common": "^18.2.0",
    "@angular/core": "^18.2.0",
    "photon-grid-core": "^1.0.2"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/common": "^18.2.0",
    "@angular/compiler": "^18.2.0",
    "@angular/compiler-cli": "^18.2.0",
    "@angular/core": "^18.2.0",
    "ng-packagr": "^18.2.0",
    "rimraf": "^6.0.1",
    "rxjs": "~7.8.0",
    "typescript": "~5.5.2",
    "zone.js": "~0.14.10"
  },
  "keywords": [
    "angular",
    "grid",
    "data-grid",
    "datatable",
    "table",
    "photon-grid",
    "enterprise-grid",
    "typescript"
  ],
  "sideEffects": false
}
